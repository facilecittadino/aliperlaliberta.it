NODE_ENV=production
PORT=8787

# Comma-separated origins allowed to call the API.
ALLOWED_ORIGINS=https://aliperlaliberta.it,https://www.aliperlaliberta.it

# Google Calendar IDs. Use the real calendar IDs from Google Calendar settings.
GOOGLE_CALENDAR_PRACTICES_ID=
GOOGLE_CALENDAR_ITALIAN_COURSE_ID=

# Google service account credentials. Keep these only on the server.
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Availability settings
TIMEZONE=Europe/Rome
SLOT_MINUTES=30
BOOKING_DURATION_MINUTES=30
WORKDAY_START=09:00
WORKDAY_END=18:00
MAX_DAYS_AHEAD=60

# Optional simple shared secret for server-to-server health/admin checks.
ADMIN_TOKEN=

# Rate limits
RATE_LIMIT_GENERAL=120
RATE_LIMIT_AVAILABILITY=60
RATE_LIMIT_BOOKING=8

# Optional anti-spam CAPTCHA. Keep false until the frontend widget is added.
REQUIRE_TURNSTILE=false
TURNSTILE_SECRET_KEY=
